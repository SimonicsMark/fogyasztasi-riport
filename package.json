{
  "name": "fogyasztasi-riport",
  "version": "1.0.2",
  "description": "Fogyasztási riport generátor",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build-dir": "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId": "hu.riport.fogyasztasi",
    "productName": "Fogyasztási Riport",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["hu"],
      "language": "1038"
    },
    "publish": {
      "provider": "github",
      "owner": "GITHUB_FELHASZNALONEV",
      "repo": "fogyasztasi-riport"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  }
}
